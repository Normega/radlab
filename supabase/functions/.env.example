# Set these in Supabase Dashboard → Edge Functions → Secrets before deploying.

# API key from resend.com dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Verified sender address in your Resend domain
FROM_EMAIL=research@radlab.vercel.app

# Public URL of the platform (no trailing slash)
SITE_URL=https://radlab.vercel.app

# From Supabase → Settings → API → service_role key (secret, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
